try {
    file = open(pyimport('os').path.join(require('sys>pyscript_path'), 'this.py'), 'r')
    local = dict()
    try {
        pyimport('builtins').exec(file.read(), dict(), local)
        s = local['s']
    } finally {
        file.close()
        del file, local
    }
} catch {
    s = "Ouh fuck! Something is wrong!"
    print(s)
}